# Django runtime configuration. These local development values are intentionally non-secret.
DJANGO_SECRET_KEY=django-insecure-local-development-only-not-a-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api

# PostgreSQL connection used by Django and the API health check.
DATABASE_URL=postgresql://rate_tracker:rate_tracker@db:5432/rate_tracker

# Redis connection used by Django's cache and Celery.
REDIS_URL=redis://redis:6379/0

# Bearer token required by the ingest endpoint introduced in Task 04.
INGEST_BEARER_TOKEN=local-demo-ingest-token

# Browser-visible Django API origin used by the dashboard introduced in Task 06.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
